  "author": { "name": "leochang", "email": "leochang210@gmail.com" },
  "license": "Noncommercial (see LICENSE; commercial use requires permission from leochang210@gmail.com)",
  "keywords": ["memory", "reflection", "self-improving", "cross-tool", "claude", "codex", "hermes"],
  "skills": ["skills/daily-reflect"],
  "commands": ["commands/reflect.md", "commands/reflect-setup.md", "commands/reflect-report.md", "commands/reflect-style.md", "commands/reflect-update.md"],
  "mcpServers": {
    "ai-reflect-memory": {
      "command": "python",
