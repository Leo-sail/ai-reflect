#!/bin/sh
# ai-reflect pre-commit hook (portable, dependency-free).
# Redundant backstop: the engine's commit_synced() already runs the full Python
# redaction scan before committing. This hook protects commits made OUTSIDE the
# engine (manual git commit), using only POSIX shell + grep so it runs anywhere
# (notably Windows git-bash, where a `python3` shebang hits the broken Store stub).
# Blocks the commit (exit 1) on: leftover git conflict markers, or obvious secrets.

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

problems=""
for f in $staged; do
  [ -f "$f" ] || continue
  # git conflict markers
  if grep -nE '^(<<<<<<<|=======|>>>>>>>)' "$f" >/dev/null 2>&1; then
    problems="$problems\n$f: leftover git conflict marker"
  fi
  # high-signal secrets (the engine does the comprehensive scan; this catches the obvious)
  if grep -nE 'AKIA[0-9A-Z]{16}|sk-ant-[A-Za-z0-9_-]{20,}|sk-[A-Za-z0-9_-]{20,}|gh[pousr]_[A-Za-z0-9]{36,}|-----BEGIN [A-Z ]*PRIVATE KEY-----|xox[baprs]-[0-9A-Za-z-]{10,}' "$f" >/dev/null 2>&1; then
    problems="$problems\n$f: suspected secret"
  fi
done

if [ -n "$problems" ]; then
  printf 'ai-reflect pre-commit blocked the commit:%b\n' "$problems" >&2
  exit 1
fi
exit 0
